def res(ok,text): return {"ok":ok,"text":text}

def run(command):
    p=subprocess.run(command,shell=True,capture_output=True,text=True,timeout=60,encoding="utf-8",errors="replace")
    out=(p.stdout+p.stderr).strip() or f"Done, code {p.returncode}"
    return res(p.returncode==0,out[:3900])

def open_app(name):
    subprocess.Popen(APPS.get(name.lower(),name),shell=True)
    return res(True,f"Opening {name}")

def close_app(name):
    killed=[]
    for p in psutil.process_iter(["name"]):
        try:
            if p.info["name"] in PROCS.get(name.lower(),[name]):
                p.terminate(); killed.append(p.info["name"])
        except: pass
    return res(bool(killed),"Closed: "+", ".join(set(killed)) if killed else f"Not found: {name}")

async def screenshot(session):
    path=Path(tempfile.gettempdir())/"pc_screen.png"
    pyautogui.screenshot().save(path)
    data=aiohttp.FormData(); data.add_field("chat_id",CHAT_ID)
    data.add_field("photo",path.open("rb"),filename="screen.png",content_type="image/png")
    async with session.post(f"https://api.telegram.org/bot{BOT_TOKEN}/sendPhoto",data=data) as r:
        j=await r.json()
    return res(j.get("ok",False),"Screenshot sent" if j.get("ok") else str(j))

async def handle(session,req):
    a=req["action"]; args=req.get("args",{})
    try:
        if a=="status": return res(True,f"PC online\n{socket.gethostname()}\n{platform.platform()}\n{datetime.now()}")
        if a=="screenshot": return await screenshot(session)
        if a=="lock": return run("rundll32.exe user32.dll,LockWorkStation")
        if a=="shutdown": return run("shutdown /s /t 5")
        if a=="restart": return run("shutdown /r /t 5")
        if a=="open": return open_app(args.get("name",""))
        if a=="close": return close_app(args.get("name",""))
        if a=="cmd": return run(args.get("command",""))
        return res(False,"Unknown action")
    except Exception as e:
        return res(False,str(e))

async def main():
    url=f"{SERVER_WS_URL.rstrip('/')}/ws?secret={AGENT_SECRET}"
    while True:
        try:
            async with aiohttp.ClientSession() as s:
                async with s.ws_connect(url,heartbeat=30) as ws:
                    async for m in ws:
                        req=m.json(); ans=await handle(s,req); ans["id"]=req["id"]; await ws.send_json(ans)
        except Exception as e:
            print("reconnect",e); await asyncio.sleep(5)

asyncio.run(main())
